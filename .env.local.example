# ============================================================
#  VARIABLES DE ENTORNO  (copia este archivo como .env.local
#  para desarrollo local, y registra estas mismas variables
#  en Vercel para produccion).
# ============================================================

# Secreto para firmar las sesiones de los dashboards.
# Pon cualquier texto largo y aleatorio. NO lo compartas.
AUTH_SECRET=pon-aqui-un-texto-largo-y-aleatorio

# Contrasenas de los dashboards privados, en formato JSON.
# La clave es el slug del dashboard; el valor es su contrasena.
DASHBOARD_PASSWORDS={"hrdt-seguimiento-sdd":"cambia-esta-clave"}
